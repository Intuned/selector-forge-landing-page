# PostHog analytics. Both vars must be NEXT_PUBLIC_-prefixed so they inline into
# the client bundle (this is a client-only, statically-exported site).

# Project API key. Leave blank to keep analytics dormant (local dev / previews).
NEXT_PUBLIC_POSTHOG_KEY=

# Ingestion host. US cloud by default; EU cloud is https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
